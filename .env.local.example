# Mailchimp — Marketing API v3
# API key from: Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=your-api-key-here
# Server prefix = last part of API key (e.g. "us1" from "abc123-us1")
MAILCHIMP_SERVER=us1
# Audience ID from: Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=your-list-id-here

# Supabase — for writing signups to LoanOS DB
# From: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://uuqedsvjlkeszrbwzizl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
